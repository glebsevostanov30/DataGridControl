<Window x:Class="DataGridControl.Dialog.SheetSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:DataGridControl.Model.Dialog"
        mc:Ignorable="d"
        Title="Выберите лист"
        Width="450"
        Height="350">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="75"/>
            <Setter Property="Margin" Value="5,0,5,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0"
                   Text="Выберите лист для загрузки:"
                   Margin="10"
                   FontWeight="Bold"
                   FontSize="13"/>

        <!-- Список листов -->
        <ListBox x:Name="SheetListBox"
                 Grid.Row="1"
                 Margin="10"
                 SelectionMode="Single"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:SheetItem}">
                    <TextBlock Text="{Binding DisplayText}"
                               FontWeight="{Binding FontWeight}"
                               Foreground="{Binding TextColor}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="10">
            <Button Content="OK"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="Отмена"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>