<Window x:Class="DataGridControl.Dialog.SelectionColumnsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:view="clr-namespace:DataGridControl.View.Dialog"
        xmlns:converter="clr-namespace:DataGridControl.Converter"
        d:DataContext="{d:DesignInstance view:SelectionColumnsDialogViewModel}"
        mc:Ignorable="d"
        Title="Выбор колонок из второй таблицы"
        Width="400"
        Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Closing="SelectionColumnsDialog_OnClosing"
        Closed="SelectionColumnsDialog_OnClosed">
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control"
                    Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control"
                    Command="{Binding RedoCommand}" />
    </Window.InputBindings>
    
    <Window.Resources>
        <converter:VisibilityToBoolConverter x:Key="VisibilityToBoolConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Выберите колонки для включения в результат:"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10">
            <Button Content="Выбрать все"
                    Width="100"
                    Margin="0,0,5,0"
                    Command="{Binding SelectAllCommand}" />
            <Button Content="Очистить"
                    Width="100"
                    Command="{Binding UnselectAllCommand}" />
        </StackPanel>

        <ListBox Grid.Row="2"
                 SelectionMode="Extended"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,10"
                 ItemsSource="{Binding mainModel.Columns}">

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Header}"
                              IsChecked="{Binding Visibility, Mode=TwoWay, Converter={StaticResource VisibilityToBoolConverter}}"
                              VerticalAlignment="Center"
                              Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.ChooseCommand}"
                              CommandParameter="{Binding}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Width="75"
                    Margin="0,0,5,0"
                    Click="ButtonBaseOk_OnClick"
                    IsCancel="True" />
            <Button Content="Отмена"
                    Width="75"
                    IsCancel="True" 
                    Click="ButtonBaseClose_OnClick"/>
        </StackPanel>
    </Grid>
</Window>